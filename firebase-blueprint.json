{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and Strava authentication details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "stravaAccessToken": { "type": "string" },
        "stravaRefreshToken": { "type": "string" },
        "stravaTokenExpiresAt": { "type": "number" },
        "stravaAthleteId": { "type": "string" },
        "fitnessLevel": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "goals": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Activity": {
      "title": "Activity",
      "description": "An athletic activity synced from Strava.",
      "type": "object",
      "properties": {
        "stravaId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "distance": { "type": "number" },
        "movingTime": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "averageHeartrate": { "type": "number" },
        "maxHeartrate": { "type": "number" }
      },
      "required": ["stravaId", "userId", "name", "startDate"]
    },
    "TrainingPlan": {
      "title": "Training Plan",
      "description": "A high-level training plan generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] }
      },
      "required": ["userId", "title", "startDate"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "A specific workout or event in the user's calendar.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "intensity": { "type": "string", "enum": ["low", "moderate", "high"] },
        "completed": { "type": "boolean" }
      },
      "required": ["userId", "title", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Synced Strava activities"
    },
    "/plans/{planId}": {
      "schema": "TrainingPlan",
      "description": "AI generated training plans"
    },
    "/events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Calendar workouts"
    }
  }
}
